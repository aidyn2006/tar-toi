{
  "name": "toi-frontend",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 7171 --strictPort",
    "build": "vite build && node scripts/generate-sitemap.cjs",
    "preview": "vite preview",
    "build:templates": "tailwindcss -i src/templates/common/tw.css -o src/templates/common/utility.css --minify && node scripts/build-templates.cjs"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1"
  }
}
